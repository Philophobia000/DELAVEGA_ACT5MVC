@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="privacy-page p-4 rounded bg-light shadow-sm">
    <h1>@ViewData["Title"]</h1>
    <p>DELAVEGA MVC Portfolio securely collects contact messages only to respond professionally. No analytics or tracking data is stored on this sample website.</p>
    <h2 class="mt-4">Information handling</h2>
    <ul>
        <li>Messages are validated and displayed only for demonstration; no data is preserved in a persistent database.</li>
        <li>Email addresses are used exclusively for response simulation and are not shared or published.</li>
        <li>This application uses standard security headers and HTTPS routing for safe transport.</li>
    </ul>
    <h2 class="mt-4">Permissions</h2>
    <p>By submitting a message through the contact form, you consent to temporary server-side processing of your request.</p>
</div>
